---
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import Base from "../layouts/Base.astro";
import { en } from "../i18n/en";

const languageSwitcher = {
  ariaLabel: en.languageSwitcher.ariaLabel,
  currentLabel: en.languageSwitcher.en,
  currentLanguage: "en" as const,
  alternateLabel: en.languageSwitcher.pl,
  alternateHref: "/pl/",
  alternateLanguage: "pl" as const,
};
---

<Base lang={en.lang} metadata={en.metadata} languageSwitcher={languageSwitcher}>
  <Hero headline={en.hero.headline} expansion={en.hero.expansion} />
  <Projects heading={en.projects.heading} arc={en.projects.arc} projects={en.projects.items} />
  <Contact slot="footer" heading={en.contact.heading} prompt={en.contact.prompt} email={en.contact.email} />
</Base>
