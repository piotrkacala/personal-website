---
import Hero from "../components/Hero.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import Base from "../layouts/Base.astro";
import { en } from "../i18n/en";
---

<Base lang={en.lang} title={en.title}>
  <Hero headline={en.hero.headline} expansion={en.hero.expansion} />
  <Projects heading={en.projects.heading} arc={en.projects.arc} projects={en.projects.items} />
  <Contact heading={en.contact.heading} prompt={en.contact.prompt} email={en.contact.email} />
</Base>
