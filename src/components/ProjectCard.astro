---
import type { ProjectBlock } from "../i18n/schema";

interface Props {
  order: string;
  title: string;
  blocks: readonly ProjectBlock[];
}

const { order, title, blocks } = Astro.props;
const titleId = `project-${order}`;
---

<article class="project-entry" aria-labelledby={titleId}>
  <p class="project-order ui-text" aria-hidden="true">{order}</p>

  <div class="project-content">
    <h3 id={titleId} class="project-title">{title}</h3>

    {
      blocks.map((block, index) => {
        if (block.type === "paragraph") {
          return (
            <p class:list={["project-paragraph", { "project-paragraph--aside": block.tone === "aside" }]}>
              {block.text}
            </p>
          );
        }

        if (block.type === "metrics") {
          const metricsHeadingId = `${titleId}-metrics-${index}`;

          return (
            <section class="project-metrics-block" aria-labelledby={metricsHeadingId}>
              <h4 id={metricsHeadingId} class="project-metrics-heading ui-text">
                {block.heading}
              </h4>

              <dl class="project-metrics">
                {block.items.map((item) => (
                  <div class="project-metric-row">
                    <dt>{item.label}</dt>
                    <dd>{item.value}</dd>
                  </div>
                ))}
              </dl>
            </section>
          );
        }

        return (
          <p class="project-link">
            <a
              href={block.href}
              class="project-link-anchor"
              rel={block.external ? "noopener noreferrer" : undefined}
              target={block.external ? "_blank" : undefined}
            >
              {block.label}
              {block.external && block.externalLabel ? (
                <span class="project-link-note"> {block.externalLabel}</span>
              ) : null}
            </a>
          </p>
        );
      })
    }
  </div>
</article>

<style>
  .project-entry {
    display: grid;
    grid-template-columns: minmax(2.75rem, auto) minmax(0, 1fr);
    gap: 0.9rem;
    align-items: start;
  }

  .project-order {
    margin: 0;
    color: var(--accent);
    font-weight: 600;
  }

  .project-content > * {
    margin: 0;
  }

  .project-content > * + * {
    margin-top: calc(var(--spacing-rhythm) * 0.7);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 1.22rem + 0.35vw, 1.55rem);
    font-weight: 600;
    line-height: 1.16;
    letter-spacing: -0.015em;
  }

  .project-paragraph {
    max-width: 62ch;
  }

  .project-paragraph--aside {
    max-width: 52ch;
    font-size: 0.98em;
  }

  .project-metrics-block {
    max-width: 62ch;
    padding-block: calc(var(--spacing-rhythm) * 0.45);
    border-top: 1px solid var(--divider);
    border-bottom: 1px solid var(--divider);
  }

  .project-metrics-heading {
    margin: 0 0 calc(var(--spacing-rhythm) * 0.32);
    color: rgb(23 20 18 / 72%);
    font-family: var(--font-body);
    font-weight: 600;
  }

  .project-metrics {
    margin: 0;
  }

  .project-metric-row {
    display: grid;
    grid-template-columns: minmax(0, 10.5rem) minmax(0, 1fr);
    gap: 0.35rem 1rem;
    padding-block: 0.42rem;
  }

  .project-metric-row + .project-metric-row {
    border-top: 1px solid rgb(23 20 18 / 10%);
  }

  .project-metric-row dt {
    margin: 0;
    font-size: var(--text-ui);
    line-height: 1.35;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: rgb(23 20 18 / 72%);
  }

  .project-metric-row dd {
    margin: 0;
    color: var(--accent);
    font-weight: 600;
    line-height: 1.4;
  }

  .project-link {
    max-width: 62ch;
  }

  .project-link-note {
    color: rgb(23 20 18 / 72%);
  }

  @media (max-width: 39.99rem) {
    .project-entry {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .project-metric-row {
      grid-template-columns: 1fr;
      gap: 0.15rem;
    }

    .project-link-anchor {
      display: inline-block;
      min-block-size: 2.75rem;
      max-width: 100%;
      padding-block: 0.5rem;
    }
  }
</style>
