---
import "../styles/global.css";

interface Props {
  lang: "en" | "pl";
  title: string;
}

const { lang, title } = Astro.props;
const alternates = [
  { lang: "en", href: "/" },
  { lang: "pl", href: "/pl/" },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />
    ))}
  </head>
  <body class="site-body">
    <main class="site-shell" id="content">
      <div class="page-column document-flow">
        <slot />
      </div>
    </main>
  </body>
</html>
