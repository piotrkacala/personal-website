---
import "../styles/global.css";

interface Props {
  lang: "en" | "pl";
  title: string;
  languageSwitcher: {
    ariaLabel: string;
    currentLabel: string;
    currentLanguage: "en" | "pl";
    alternateLabel: string;
    alternateHref: string;
    alternateLanguage: "en" | "pl";
  };
}

const { lang, title, languageSwitcher } = Astro.props;
const siteUrl = "https://piotrkacala.pl";
const fontPreloads = [
  "/fonts/source-sans-3-latin.woff2",
  "/fonts/source-sans-3-latin-ext.woff2",
  "/fonts/spectral-600-latin.woff2",
  "/fonts/spectral-600-latin-ext.woff2",
];
const alternates = [
  { lang: "en", href: new URL("/", siteUrl).toString() },
  { lang: "pl", href: new URL("/pl/", siteUrl).toString() },
  { lang: "x-default", href: new URL("/", siteUrl).toString() },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {fontPreloads.map((href) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />
    ))}
  </head>
  <body class="site-body">
    <main class="site-shell" id="content">
      <div class="page-column">
        <header class="mb-5 border-b pb-4" style="border-color: var(--divider);">
          <nav
            aria-label={languageSwitcher.ariaLabel}
            class="ui-text flex min-h-11 items-center justify-end gap-3 uppercase"
          >
            <span
              aria-current="page"
              lang={languageSwitcher.currentLanguage}
              class="inline-flex min-h-11 items-center border-b pb-0.5 font-semibold"
              style="color: var(--text); border-color: currentColor;"
            >
              {languageSwitcher.currentLabel}
            </span>
            <span aria-hidden="true" style="color: var(--divider);">/</span>
            <a
              href={languageSwitcher.alternateHref}
              hreflang={languageSwitcher.alternateLanguage}
              lang={languageSwitcher.alternateLanguage}
              class="inline-flex min-h-11 items-center"
            >
              {languageSwitcher.alternateLabel}
            </a>
          </nav>
        </header>
        <div class="document-flow">
          <slot />
        </div>
      </div>
    </main>
  </body>
</html>
