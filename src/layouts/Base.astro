---
import "../styles/global.css";

interface Props {
  lang: "en" | "pl";
  title: string;
}

const { lang, title } = Astro.props;
const siteUrl = "https://piotrkacala.pl";
const fontPreloads = [
  "/fonts/source-sans-3-latin.woff2",
  "/fonts/source-sans-3-latin-ext.woff2",
  "/fonts/spectral-600-latin.woff2",
  "/fonts/spectral-600-latin-ext.woff2",
];
const alternates = [
  { lang: "en", href: new URL("/", siteUrl).toString() },
  { lang: "pl", href: new URL("/pl/", siteUrl).toString() },
  { lang: "x-default", href: new URL("/", siteUrl).toString() },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {fontPreloads.map((href) => (
      <link rel="preload" href={href} as="font" type="font/woff2" crossorigin />
    ))}
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.lang} href={alternate.href} />
    ))}
  </head>
  <body class="site-body">
    <main class="site-shell" id="content">
      <div class="page-column document-flow">
        <slot />
      </div>
    </main>
  </body>
</html>
